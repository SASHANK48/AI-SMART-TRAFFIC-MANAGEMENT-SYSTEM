xtType | undefined>(undefined);\r\n\r\nexport const AuthProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {\r\n  const [user, setUser] = useState<User | null>(null);\r\n\r\n  useEffect(() => {\r\n    const storedUser = localStorage.getItem('userInfo');\r\n    if (storedUser) {\r\n      try {\r\n        setUser(JSON.parse(storedUser));\r\n      } catch (e) {\r\n        console.error('Failed to parse user info', e);\r\n      }\r\n    }\r\n  }, []);\r\n\r\n  const login = (userData: User) => {\r\n    setUser(userData);\r\n    localStorage.setItem('userInfo', JSON.stringify(userData));\r\n  };\r\n\r\n  const logout = () => {\r\n    setUser(null);\r\n    localStorage.removeItem('userInfo');\r\n  };\r\n\r\n  return (\r\n    <AuthContext.Provider value={{ user, login, logout }}>\r\n      {children}\r\n    </AuthContext.Provider>\r\n  );\r\n};\r\n\r\nexport const useAuth = () => {\r\n  const context = useContext(AuthContext);\r\n  if (context === undefined) {\r\n    throw new Error('useAuth must be used within an AuthProvider');\r\n  }\r\n  return context;\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sashank anjani\\Downloads\\traffic management system\\project\\src\\contexts\\SocketContext.tsx","messages":[{"ruleId":null,"nodeType":null,"fatal":true,"severity":2,"message":"Parsing error: An identifier or keyword cannot immediately follow a numeric literal.","line":1,"column":1}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":1,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"2import React, { createContext, useContext, useEffect, useState } from 'react';\r\nimport { io, Socket } from 'socket.io-client';\r\n\r\ninterface SocketContextType {\r\n  socket: Socket | null;\r\n  isConnected: boolean;\r\n}\r\n\r\nconst SocketContext = createContext<SocketContextType>({ socket: null, isConnected: false });\r\n\r\nexport const SocketProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {\r\n  const [socket, setSocket] = useState<Socket | null>(null);\r\n  const [isConnected, setIsConnected] = useState(false);\r\n\r\n  useEffect(() => {\r\n    const socketInstance = io('http://localhost:5000', {\r\n      transports: ['websocket', 'polling']\r\n    });\r\n\r\n    socketInstance.on('connect', () => {\r\n      setIsConnected(true);\r\n      console.log('Socket connected');\r\n    });\r\n\r\n    socketInstance.on('disconnect', () => {\r\n      setIsConnected(false);\r\n      console.log('Socket disconnected');\r\n    });\r\n\r\n    setSocket(socketInstance);\r\n\r\n    return () => {\r\n      socketInstance.disconnect();\r\n    };\r\n  }, []);\r\n\r\n  return (\r\n    <SocketContext.Provider value={{ socket, isConnected }}>\r\n      {children}\r\n    </SocketContext.Provider>\r\n  );\r\n};\r\n\r\nexport const useSocket = () => useContext(SocketContext);\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sashank anjani\\Downloads\\traffic management system\\project\\src\\contexts\\ThemeContext.tsx","messages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Use a new file to share constants or functions between components.","line":42,"column":14,"nodeType":"Identifier","messageId":"namedExport","endLine":42,"endColumn":22}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import React, { createContext, useContext, useEffect, useState } from 'react';\r\n\r\ntype Theme = 'light' | 'dark';\r\n\r\ninterface ThemeContextType {\r\n  theme: Theme;\r\n  toggleTheme: () => void;\r\n}\r\n\r\nconst ThemeContext = createContext<ThemeContextType | undefined>(undefined);\r\n\r\nexport const ThemeProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {\r\n  const [theme, setTheme] = useState<Theme>('light');\r\n\r\n  useEffect(() => {\r\n    const savedTheme = localStorage.getItem('theme') as Theme;\r\n    if (savedTheme) {\r\n      setTheme(savedTheme);\r\n    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {\r\n      setTheme('dark');\r\n    }\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    localStorage.setItem('theme', theme);\r\n    if (theme === 'dark') {\r\n      document.documentElement.classList.add('dark');\r\n    } else {\r\n      document.documentElement.classList.remove('dark');\r\n    }\r\n  }, [theme]);\r\n\r\n  const toggleTheme = () => setTheme((prev) => (prev === 'light' ? 'dark' : 'light'));\r\n\r\n  return (\r\n    <ThemeContext.Provider value={{ theme, toggleTheme }}>\r\n      {children}\r\n    </ThemeContext.Provider>\r\n  );\r\n};\r\n\r\nexport const useTheme = () => {\r\n  const context = useContext(ThemeContext);\r\n  if (context === undefined) {\r\n    throw new Error('useTheme must be used within a ThemeProvider');\r\n  }\r\n  return context;\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sashank anjani\\Downloads\\traffic management system\\project\\src\\hooks\\useTrafficData.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sashank anjani\\Downloads\\traffic management system\\project\\src\\main.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sashank anjani\\Downloads\\traffic management system\\project\\src\\pages\\Admin.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\sashank anjani\\Downloads\\traffic management system\\project\\src\\pages\\Alerts.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarni