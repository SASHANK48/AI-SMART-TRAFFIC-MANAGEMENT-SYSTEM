# MongoDB Atlas connection string
# Replace with your MongoDB Atlas URI or local MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/traffic_db?retryWrites=true&w=majority

# Server
PORT=5000

# CORS - comma-separated origins (use * for development)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Traffic simulation interval in milliseconds (default: 5000 = 5 seconds)
TRAFFIC_UPDATE_INTERVAL=5000
